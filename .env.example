# Zerobus producer config (run locally)
ZEROBUS_SERVER_ENDPOINT=https://<workspace-id>.zerobus.<region>.cloud.databricks.com
DATABRICKS_WORKSPACE_URL=https://fevm-startups.cloud.databricks.com
ZEROBUS_TABLE_NAME=startups_catalog.dw_zerobus.zerobus_events
DATABRICKS_CLIENT_ID=<service-principal-client-id>
DATABRICKS_CLIENT_SECRET=<service-principal-client-secret>
